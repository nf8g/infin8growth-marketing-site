{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/work", "destination": "/work.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/subscribe-confirmed", "destination": "/subscribe-confirmed.html" },
    { "source": "/unsubscribed", "destination": "/unsubscribed.html" },
    { "source": "/subscribe-error", "destination": "/subscribe-error.html" }
  ]
}
